        'format': 'bestaudio/best',
        'outtmpl': os.path.join(download_folder, '%(title)s.%(ext)s'),
        'restrictfilenames': True,
        'noplaylist': True,
        # 嘗試解碼成 MP3 (若環境無 FFmpeg 則維持 M4A/WebM)
        'postprocessors': [{
            'key': 'FFmpegExtractAudio',
            'preferredcodec': 'mp3',
            'preferredquality': '192',
        }],
    }
    
    try:
        with yt_dlp.YoutubeDL(ydl_opts) as ydl:
            info = ydl.extract_info(url, download=True)
            print("\n" + "="*50)
            print(f"🎉 音樂下載成功！")
            print(f"🎵 歌名: {info.get('title')}")
            print(f"💾 檔案已安全儲存在您的「下載」資料夾中！")
            print("="*50)
            
            # 下載成功後自動開啟資料夾
            open_download_folder(download_folder)

    except yt_dlp.utils.PostProcessingError:
        # 當無安裝 FFmpeg 時，會跳過轉檔，但音樂檔 (.m4a/.webm) 其實已完好下載
        print("\n" + "="*50)
        print("🎉 音樂下載成功！(已下載原生高品質音訊 m4a/webm 檔案)")
        print("💡 提示：若需自動轉 MP3 格式，可在電腦中安裝 FFmpeg。")
        print("💾 檔案已安全儲存在您的「下載」資料夾中！")
        print("="*50)
        open_download_folder(download_folder)
        
    except Exception as e:
        print(f"\n❌ 下載失敗，可能原因：\n1. 網址錯誤\n2. 網路連線中斷\n3. YouTube 官方機制變更 (請更新套件: pip install -U yt-dlp)")
        print(f"詳細錯誤訊息: {e}")

if __name__ == "__main__":
    print("==================================================")
    print("        YouTube 音樂高音質快速下載器 (自帶存檔定位)")
    print("==================================================")
    
    url = input("請貼上 YouTube 影片或音樂網址: ").strip()
    if url:
        download_audio(url)
    else:
        print("❌ 未輸入網址，程式結束。")
    
    input("\n[結束] 按下任意鍵退出視窗...")
</textarea>
