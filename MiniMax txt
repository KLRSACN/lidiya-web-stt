import sys
import subprocess
import platform

# 檢查並安裝 yt-dlp 庫
def install_dependencies():
    print("==================================================")
    print("正在為您檢查並自動安裝必要下載套件 (yt-dlp)...")
    print("==================================================")
    try:
        subprocess.check_call([sys.executable, "-m", "pip", "install", "yt-dlp"])
        print("\n🎉 必要套件安裝完成！")
    except Exception as e:
        print(f"\n❌ 套件安裝失敗，請嘗試手動在終端機輸入: pip install yt-dlp\n錯誤訊息: {e}")
        input("\n按下任意鍵結束...")
        sys.exit(1)

try:
    import yt_dlp
except ImportError:
    install_dependencies()
    import yt_dlp

# 自動打開下載目錄
def open_download_folder(path):
    print(f"\n📂 下載完成！正在為您自動打開儲存資料夾...")
    try:
        if platform.system() == "Windows":
            os.startfile(path)
        elif platform.system() == "Darwin": # macOS
            subprocess.Popen(["open", path])
        else: # Linux
            subprocess.Popen(["xdg-open", path])
    except Exception as e:
        print(f"無法自動開啟資料夾，請手動前往：{path}")

