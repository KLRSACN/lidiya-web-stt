        </div>
    </main>

    <!-- Footer -->
    <footer class="bg-gray-950 border-t border-gray-800 py-6 text-center text-xs text-gray-500">
        <p class="mb-2">© 2026 YouTube 音樂下載 & MiniMax 提示詞大師. All rights reserved.</p>
        <p>本工具採用國產高效能 Gemini 2.5 進行音樂解構，產出最佳生成配方。</p>
    </footer>

    <!-- Script Area -->
    <script>
        // API Configuration (環境自動提供，無需手動配置金鑰)
        const apiKey = ""; 
        let globalSourceUrl = ""; // 用於全域存放自動尋找到的 YouTube 網址

        // 自製彈窗控制
        function showCustomAlert(msg) {
            document.getElementById('alert-message').innerText = msg;
            document.getElementById('custom-alert').classList.remove('hidden');
        }

        function closeAlert() {
            document.getElementById('custom-alert').classList.add('hidden');
        }

        // Exponential backoff runner
        async function fetchWithBackoff(url, options, retries = 5, delay = 1000) {
            try {
                const res = await fetch(url, options);
                if (!res.ok) {
                    throw new Error(`HTTP 錯誤狀態碼: ${res.status}`);
                }
                return await res.json();
            } catch (error) {
                if (retries > 0) {
                    await new Promise(resolve => setTimeout(resolve, delay));
                    return fetchWithBackoff(url, options, retries - 1, delay * 2);
                }
                throw error;
            }
        }

        // Switch Tabs
        function switchTab(tabId, btn) {
            document.querySelectorAll('.tab-btn').forEach(b => {
                b.classList.remove('bg-violet-600', 'text-white', 'shadow-md');
                b.classList.add('bg-gray-900', 'text-gray-300');
            });
            btn.classList.add('bg-violet-600', 'text-white', 'shadow-md');
            btn.classList.remove('bg-gray-900', 'text-gray-300');

            if (tabId === 'minimax-tab') {
                document.getElementById('minimax-tab-content').classList.remove('hidden');
                document.getElementById('downloader-tab-content').classList.add('hidden');
            } else {
                document.getElementById('minimax-tab-content').classList.add('hidden');
                document.getElementById('downloader-tab-content').classList.remove('hidden');
            }
        }

        // 複製 YouTube 來源網址
        function copySourceUrl() {
            if (globalSourceUrl) {
                const tempInput = document.createElement("textarea");
                tempInput.value = globalSourceUrl;
                document.body.appendChild(tempInput);
                tempInput.select();
                document.execCommand("copy");
                document.body.removeChild(tempInput);
                showCustomAlert("YouTube 來源網址已複製到您的剪貼簿！");
            } else {
                showCustomAlert("目前尚未分析出有效的 YouTube 網址。");
            }
        }

        // Core Analysis trigger
        async function startAnalysis() {
            const query = document.getElementById('musicQuery').value.trim();
            const modifier = document.getElementById('styleModifier').value.trim();

            if (!query) {
                showCustomAlert("請先輸入 YouTube 網址或歌曲名稱！");
                return;
            }

            // UI state updates
            document.getElementById('empty-state').classList.add('hidden');
            document.getElementById('result-state').classList.add('hidden');
            document.getElementById('loading-state').classList.remove('hidden');

            const minimaxTabBtn = document.querySelectorAll('.tab-btn')[0];
            switchTab('minimax-tab', minimaxTabBtn);

            try {
                // 升級：1.要求AI找出對應的YouTube連結 2.要求歌詞必須在核心不變下，字數與句式高度對齊以穩定旋律。
                const systemPrompt = `
You are an elite music analyst and MiniMax (HaiLuo AI Music) Prompt Engineer. Your job is to analyze the requested YouTube video or song name. You MUST use Google Search to find the exact official or high-quality YouTube video URL of this song. 

You must output EXACTLY the following sections in Traditional Chinese (繁體中文). Keep the output clean.

Output format should follow this exact style so the frontend JS can parse it:
1. "Source URL: [Found YouTube URL]" - This is mandatory. You must search and output the YouTube link you found.
2. "BPM: [value]"
3. "Genre: [value]"
4. "Vocal: [value]"
5. "Instruments: [value]"
6. "Style Tags: [comma-separated list of tags in English optimal for MiniMax]"
7. "Lyrics: [Rewritten lyrics]"
   - CRITICAL REQUIREMENT FOR LYRICS STABILIZATION: You must REWRITE the lyrics to avoid copyright issues, but you MUST strictly match the exact syllable/character count per line, the sentence structures, and rhyming patterns of the original song (歌詞改寫時，每行字數、節奏 pacing 與押韻格式必須與原版歌詞 100% 高度對齊、字數相同、格式對稱，這樣能確保 MiniMax 生成音樂時，音律分配完美對齊，旋律與曲調穩定不跑調跑歌). Preserve all bracket tags like [Intro], [Verse 1], [Chorus], [Bridge], [Outro] etc., where they fit naturally.
8. "Explanation: [Detailed musical structural analysis]"
`;

                const userQuery = `分析目標歌曲: ${query}
風格調整需求 (如果有的話): ${modifier || '依照原曲風格重現'}`;

                const endpoint = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
                
                const payload = {
                    contents: [{ parts: [{ text: userQuery }] }],
                    tools: [{ "google_search": {} }],
                    systemInstruction: { parts: [{ text: systemPrompt }] }
                };

                const data = await fetchWithBackoff(endpoint, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const rawText = data.candidates?.[0]?.content?.parts?.[0]?.text;
                if (!rawText) {
                    throw new Error("未能從 AI 取得有效回應。");
                }

                // Process and Render output
                parseAndDisplayResult(rawText, query);

            } catch (err) {
                console.error(err);
                document.getElementById('loading-state').classList.add('hidden');
                document.getElementById('empty-state').classList.remove('hidden');
                showCustomAlert("分析失敗，請檢查網路連線。錯誤資訊: " + err.message);
            }
        }

        // Parse AI response to populate UI elements
        function parseAndDisplayResult(text, rawQuery) {
            document.getElementById('loading-state').classList.add('hidden');
            document.getElementById('result-state').classList.remove('hidden');

            // 1. 提取 AI 搜尋到的 YouTube 來源網址
            const urlMatch = text.match(/(?:Source URL|來源網址|網址)[：:]?\s*(https?:\/\/[^\s]+)/i);
            const sourceUrlElement = document.getElementById('meta-source-url');
            if (urlMatch) {
                globalSourceUrl = urlMatch[1].trim();
                sourceUrlElement.href = globalSourceUrl;
                sourceUrlElement.innerText = "已尋獲音樂影片";
                sourceUrlElement.classList.remove('text-gray-500');
                sourceUrlElement.classList.add('text-violet-400');
            } else {
                // 如果是使用者貼上來的原本就是網址
                if (rawQuery.startsWith('http')) {
                    globalSourceUrl = rawQuery;
                    sourceUrlElement.href = globalSourceUrl;
                    sourceUrlElement.innerText = "已尋獲音樂影片";
                    sourceUrlElement.classList.remove('text-gray-500');
                    sourceUrlElement.classList.add('text-violet-400');
                } else {
                    globalSourceUrl = "";
                    sourceUrlElement.href = "#";
                    sourceUrlElement.innerText = "點此打開影片";
                    sourceUrlElement.classList.add('text-gray-500');
                    sourceUrlElement.classList.remove('text-violet-400');
                }
            }

            // 2. 提取其餘資訊
            document.getElementById('meta-title').innerText = rawQuery.replace(/https?:\/\/[^\s]+/, '').trim() || "YouTube 音樂連結";
            
            const genreMatch = text.match(/(?:曲風|風格|Genre)[：:]?\s*([^\n]+)/i);
            document.getElementById('meta-genre').innerText = genreMatch ? genreMatch[1].trim() : "Pop / Electronic";

            const bpmMatch = text.match(/(?:BPM|速度|Tempo)[：:]?\s*([^\n]+)/i);
            document.getElementById('meta-bpm').innerText = bpmMatch ? bpmMatch[1].trim() : "85 - 110 BPM";

            const vocalMatch = text.match(/(?:人聲|歌手|人聲特色|Vocal)[：:]?\s*([^\n]+)/i);
            document.getElementById('meta-vocal').innerText = vocalMatch ? vocalMatch[1].trim() : "溫柔清澈女聲";

            const instMatch = text.match(/(?:樂器|編製|Instruments)[：:]?\s*([^\n]+)/i);
            document.getElementById('meta-instruments').innerText = instMatch ? instMatch[1].trim() : "鋼琴、環境電子音效";

            const stylePromptBlock = text.match(/[\w\s,-]+vocal[\w\s,-]+/i) || text.match(/(?:風格標籤|Style Tags)[：:]?\s*([^\n#]+)/i);
            if (stylePromptBlock) {
                document.getElementById('style-prompt-text').value = stylePromptBlock[0].replace(/風格標籤|Style Tags|[：:]/g, '').trim();
            } else {
                document.getElementById('style-prompt-text').value = "100 BPM, pop, emotional melodic female vocal, acoustic piano, soft pads, high quality production";
            }

            // 提取歌詞
            let lyricsContent = "";
            const lines = text.split('\n');
            let capturingLyrics = false;
            
            for (let line of lines) {
                if (line.includes('[') || line.includes('Intro') || line.includes('Chorus') || line.includes('歌詞') || line.includes('Lyrics')) {
                    capturingLyrics = true;
                }
                // 避免捕獲到後面解釋的部分
                if (capturingLyrics && (line.includes('Explanation') || line.includes('結構分析') || line.includes('深度歌曲'))) {
                    capturingLyrics = false;
                }
                if (capturingLyrics) {
                    lyricsContent += line + "\n";
                }
            }
            
            if (lyricsContent.length > 50) {
                document.getElementById('lyrics-prompt-text').value = lyricsContent.trim();
            } else {
                document.getElementById('lyrics-prompt-text').value = text;
            }

            // Set Full Explanation
            const formattedExplanation = text.split('\n').map(line => `<p class="mb-1">${line}</p>`).join('');
            document.getElementById('full-analysis-text').innerHTML = formattedExplanation;
        }

        // Custom copy command for safely operating within iframe environments
        function copyPrompt(textareaId, buttonId) {
            const copyText = document.getElementById(textareaId).value;
            executeCopyAction(copyText, buttonId, "已複製！");
        }

        // One click copy style prompt and lyrics combined
        function copyAllToClipboard() {
            const title = document.getElementById('meta-title').innerText || "未命名歌曲";
            const style = document.getElementById('style-prompt-text').value;
            const lyrics = document.getElementById('lyrics-prompt-text').value;
            
            // 順序調整：歌名 -> 歌詞 -> 風格標籤
            // 使用完全不發音的星號符號與多重換行進行簡單隔離，不加入任何語音引擎可能誤讀的中英文備註
            const combined = `${title}\n\n***\n\n${lyrics}\n\n***\n\n${style}`;
            
            executeCopyAction(combined, 'copy-all-btn', '成功複製風格與歌詞！');
        }

        // 獨立變換歌詞功能 (同樣限制字數與韻律保持穩定，防止旋律跑掉)
        async function modifyLyrics() {
            const currentLyrics = document.getElementById('lyrics-prompt-text').value.trim();
            const instruction = document.getElementById('lyricModifierInput').value.trim();

            if (!currentLyrics) {
                showCustomAlert("目前沒有可變換的歌詞！請先進行歌曲分析。");
                return;
            }
            if (!instruction) {
                showCustomAlert("請輸入歌詞變換指令（例如：改為古風、翻譯成英文、憂傷感）！");
                return;
            }

            // 顯示歌詞專用載入遮罩
            const overlay = document.getElementById('lyrics-loading-overlay');
            if (overlay) overlay.classList.remove('hidden');

            try {
                const systemPrompt = `
You are an expert lyricist and MiniMax (HaiLuo AI) prompt creator. Your task is to rewrite, adapt, or transform the provided lyrics based on the user's specific instruction. 

CRITICAL旋律穩定指令：
1. You MUST keep the EXACT same syllable/character count per line as the original lyrics. (每一行的字數必須與原歌詞完全相等，句型 pacing 必須完全一致)
2. You MUST preserve all structural bracket tags (such as [Intro], [Verse 1], [Chorus], [Bridge], [Outro], etc.) exactly where they fit.
3. You MUST maintain the same basic rhyming rules (押韻模式與句式對稱必須完全保留).
Output ONLY the rewritten lyrics. Do not add any introductory or concluding text. This is crucial for stabilizing the generated melody flow in MiniMax.
`;
                const userQuery = `Original Lyrics:\n${currentLyrics}\n\nTransformation Instruction: ${instruction}`;

                const endpoint = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
                
                const payload = {
                    contents: [{ parts: [{ text: userQuery }] }],
                    systemInstruction: { parts: [{ text: systemPrompt }] }
                };

                const data = await fetchWithBackoff(endpoint, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                const rawText = data.candidates?.[0]?.content?.parts?.[0]?.text;
                if (!rawText) {
                    throw new Error("未能從 AI 取得有效回應。");
                }

                // 更新歌詞顯示並清空指令框
                document.getElementById('lyrics-prompt-text').value = rawText.trim();
                document.getElementById('lyricModifierInput').value = "";
                
            } catch (err) {
                console.error(err);
                showCustomAlert("歌詞變換失敗，請確認網路連線。錯誤資訊: " + err.message);
            } finally {
                if (overlay) overlay.classList.add('hidden');
            }
        }

        // Reusable copy executor
        function executeCopyAction(textToCopy, buttonId, successMsg) {
            const tempInput = document.createElement("textarea");
            tempInput.value = textToCopy;
            document.body.appendChild(tempInput);
            tempInput.select();
            document.execCommand("copy");
            document.body.removeChild(tempInput);

            // Change button text to give feedback
            const btn = document.getElementById(buttonId);
            const originalHTML = btn.innerHTML;
            
            btn.innerHTML = `<i class="fas fa-check"></i> ${successMsg}`;
            
            const originalClass = btn.className;
            if (buttonId === 'copy-all-btn') {
                btn.className = "w-full sm:w-auto px-6 py-3 bg-gradient-to-r from-green-500 to-emerald-600 text-white font-bold rounded-xl shadow-lg transition-all flex items-center justify-center gap-2";
            } else {
                btn.classList.remove('bg-gray-800', 'text-violet-300', 'text-pink-300');
                btn.classList.add('bg-green-600', 'text-white');
            }

            setTimeout(() => {
                btn.innerHTML = originalHTML;
                btn.className = originalClass;
            }, 2500);
        }

        // Shortcut online helper opener (自動複製 YouTube 網址並跳轉)
        function openOnlineConverter(url) {
            if (globalSourceUrl) {
                const tempInput = document.createElement("textarea");
                tempInput.value = globalSourceUrl;
                document.body.appendChild(tempInput);
                tempInput.select();
                document.execCommand("copy");
                document.body.removeChild(tempInput);
                
                showCustomAlert("系統已為您自動複製網址！即將開啟下載頁面，您只需在下載框中貼上 (Ctrl+V) 網址即可！");
            } else {
                showCustomAlert("尚未分析取得 YouTube 網址，已直接為您開啟下載平台。");
            }
            setTimeout(() => {
                window.open(url, '_blank');
            }, 1000);
        }
    </script>
